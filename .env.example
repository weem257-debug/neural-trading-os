# ============================================================
# Trading Dashboard — Environment Variables
# ============================================================
# Copy this file to .env and fill in your keys:
#   cp .env.example .env
#
# IMPORTANT: Never commit .env to version control!
# ============================================================

# ----------------------------------------------------------
# Application
# ----------------------------------------------------------
APP_NAME="Trading Dashboard"
APP_VERSION="0.1.0"
DEBUG=false
ENVIRONMENT=development  # Set to "production" on Railway/Render

# ----------------------------------------------------------
# Production URL (CORS — set to your deployed frontend URL)
# ----------------------------------------------------------
# Example: PRODUCTION_URL=https://neural-trading-os.up.railway.app
PRODUCTION_URL=

# ----------------------------------------------------------
# LLM Providers (Anthropic is primary)
# ----------------------------------------------------------
# Required — get at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optional — fallback or alternative models
OPENAI_API_KEY=sk-...

# Model selection (defaults work fine)
ANTHROPIC_MODEL_ANALYSIS=claude-sonnet-4-6
ANTHROPIC_MODEL_FAST=claude-haiku-4-5-20251001

# ----------------------------------------------------------
# Market Data APIs (at least one recommended)
# ----------------------------------------------------------
# Yahoo Finance — free, no key needed (enabled by default)
YAHOO_FINANCE_ENABLED=true

# Finnhub — real-time data: https://finnhub.io/
FINNHUB_API_KEY=

# Alpha Vantage — alternative data: https://www.alphavantage.co/
ALPHA_VANTAGE_API_KEY=

# Polygon.io — institutional-grade: https://polygon.io/
POLYGON_API_KEY=

# ----------------------------------------------------------
# Crypto Exchanges
# ----------------------------------------------------------
# Binance
BINANCE_API_KEY=
BINANCE_SECRET_KEY=

# Bybit
BYBIT_API_KEY=
BYBIT_SECRET_KEY=

# Coinbase Advanced Trade
COINBASE_API_KEY=
COINBASE_SECRET_KEY=

# ----------------------------------------------------------
# Stock Brokers
# ----------------------------------------------------------
# Alpaca (paper trading: https://alpaca.markets/)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets  # Use paper for testing

# Interactive Brokers (TWS must be running locally)
INTERACTIVE_BROKERS_HOST=127.0.0.1
INTERACTIVE_BROKERS_PORT=7497

# ----------------------------------------------------------
# Broker-Integrationen (Phase 1 — Offizielle APIs)
# ----------------------------------------------------------

# Bitpanda — Offizielle REST API
# API-Key erstellen: https://web.bitpanda.com/user/api
BITPANDA_API_KEY=

# Comdirect — Offizielle OAuth2 API + PHOTO-TAN
# App registrieren: https://developer.comdirect.de
# WICHTIG: Access Token laeuft ab (~20 Min). Per Settings-UI setzen.
COMDIRECT_CLIENT_ID=
COMDIRECT_CLIENT_SECRET=
COMDIRECT_ACCESS_TOKEN=  # Wird nach OAuth2+PHOTO-TAN Flow gesetzt

# ----------------------------------------------------------
# Broker-Integrationen (Phase 2 — Community-Bibliotheken)
# ----------------------------------------------------------

# DEGIRO — Community-Lib: pip install degiro-connector
DEGIRO_USERNAME=
DEGIRO_PASSWORD=
DEGIRO_TOTP_TOKEN=  # Nur wenn 2FA aktiv

# Flatex — FinTS/HBCI (BLZ: 30080080)
# pip install python-fints
# ACHTUNG: PIN wird NICHT in der DB gespeichert — nur als Env-Var oder per Request
FLATEX_FINTS_USER=   # Kundennummer
FLATEX_FINTS_PIN=    # Online-Banking PIN (SICHER verwahren!)
FLATEX_FINTS_ACCOUNT=  # IBAN des Verrechungskontos (optional)

# Crowdestor — Inoffizielle Web-API (E-Mail + Passwort)
CROWDESTOR_EMAIL=
CROWDESTOR_PASSWORD=

# ----------------------------------------------------------
# Broker-Integrationen (Phase 3 — Reverse Engineering)
# ----------------------------------------------------------

# Trade Republic — WebSocket + proprietaeres Protokoll
# Bibliothek: pip install pytr
# ACHTUNG: Verstoss gegen TR-AGB moeglich — Eigenverantwortung!
# 2FA-Bestaetigung in der App bei erstem Connect erforderlich.
TR_PHONE_NUMBER=  # z.B. +49123456789
TR_PIN=           # 4-stellige App-PIN

# WH SelfInvest — cTrader Open API
# OAuth2-App registrieren: https://connect.spotware.com/
WH_CTRADER_CLIENT_ID=
WH_CTRADER_CLIENT_SECRET=
WH_CTRADER_ACCESS_TOKEN=  # Nach OAuth2-Flow setzen
WH_CTRADER_ACCOUNT_ID=    # Trading Account ID

# ----------------------------------------------------------
# Database
# ----------------------------------------------------------
# SQLite (default — no setup needed)
DATABASE_URL=sqlite:///./trading_dashboard.db

# PostgreSQL (for production / Docker)
# DATABASE_URL=postgresql://trading:trading@localhost:5432/trading

# Redis (optional — for caching and pub/sub)
REDIS_URL=redis://localhost:6379

# ----------------------------------------------------------
# Trading Mode (SAFETY CRITICAL)
# ----------------------------------------------------------
# Keep ENABLE_LIVE_TRADING=false until you've verified everything!
ENABLE_LIVE_TRADING=false
ENABLE_PAPER_TRADING=true
ENABLE_BACKTESTING=true
ENABLE_SENTIMENT=true
ENABLE_AI_SIGNALS=true

# ----------------------------------------------------------
# Risk Limits
# ----------------------------------------------------------
MAX_POSITION_SIZE_PCT=0.05    # 5% max per position
MAX_DAILY_LOSS_PCT=0.02       # 2% daily stop-loss
MAX_LEVERAGE=1.0              # No leverage by default

# ----------------------------------------------------------
# Frontend (Next.js)
# ----------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ----------------------------------------------------------
# Repo Paths (absolute paths on Windows)
# ----------------------------------------------------------
# These default to sibling directories — adjust if repos are elsewhere
TRADINGAGENTS_PATH=C:\Users\janwe\claude\tradingbot\TradingAgents
AI_TRADER_PATH=C:\Users\janwe\claude\tradingbot\AI-Trader
DAILY_ANALYSIS_PATH=C:\Users\janwe\claude\tradingbot\daily_stock_analysis
VIBE_TRADING_PATH=C:\Users\janwe\claude\tradingbot\Vibe-Trading
QLIB_PATH=C:\Users\janwe\claude\tradingbot\qlib
NAUTILUS_PATH=C:\Users\janwe\claude\tradingbot\nautilus_trader
FINGPT_PATH=C:\Users\janwe\claude\tradingbot\FinGPT
FINROBOT_PATH=C:\Users\janwe\claude\tradingbot\FinRobot
JESSE_PATH=C:\Users\janwe\claude\tradingbot\jesse
