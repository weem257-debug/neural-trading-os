{
  "appId": "com.neuraltrading.os",
  "appName": "Neural Trading OS",
  "webDir": "out",
  "server": {
    "androidScheme": "https"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#060d1f",
      "androidSplashResourceName": "splash",
      "showSpinner": false
    },
    "StatusBar": {
      "style": "Dark",
      "backgroundColor": "#060d1f"
    }
  },
  "android": {
    "buildOptions": {
      "releaseType": "APK"
    }
  }
}
